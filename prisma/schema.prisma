generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  CASHIER
  INVENTORY
  ACCOUNTING
}

enum SerialStatus {
  IN_STOCK
  RESERVED
  SOLD
  CLAIMED
  RETURNED
  LOST
}

enum DocumentType {
  QUOTATION
  DELIVERY_NOTE
  RECEIPT
  TAX_INVOICE
}

enum DocumentStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
  MIXED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CASHIER)
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String          @id @default(uuid())
  sku           String          @unique
  barcode       String?         @unique
  name          String
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  costPrice     Decimal         @db.Decimal(12, 2)
  price         Decimal         @db.Decimal(12, 2)
  stockQuantity Int             @default(0)
  reorderPoint  Int             @default(0)
  requireSerial Boolean         @default(false)
  serialNumbers SerialNumber[]
  documentItems DocumentItem[]
  movements     StockMovement[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([categoryId])
  @@index([name])
}

model SerialNumber {
  id              String          @id @default(uuid())
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  serialNumber    String          @unique
  warrantyStartAt DateTime?
  warrantyEndAt   DateTime?
  status          SerialStatus    @default(IN_STOCK)
  documentItems   DocumentItem[]
  movements       StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([productId, status])
}

model Customer {
  id        String     @id @default(uuid())
  name      String
  taxId     String?
  address   String?    @db.Text
  phone     String?
  email     String?
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([name])
  @@index([phone])
}

model Document {
  id                  String           @id @default(uuid())
  documentNo          String           @unique
  type                DocumentType
  customerId          String?
  customer            Customer?        @relation(fields: [customerId], references: [id])
  referenceDocumentId String?
  referenceDocument   Document?        @relation("DocumentReference", fields: [referenceDocumentId], references: [id])
  childDocuments      Document[]       @relation("DocumentReference")
  subtotalAmount      Decimal          @db.Decimal(12, 2)
  discountAmount      Decimal          @default(0) @db.Decimal(12, 2)
  vatAmount           Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal          @db.Decimal(12, 2)
  status              DocumentStatus   @default(DRAFT)
  paymentMethod       PaymentMethod?
  issuedAt            DateTime?
  expiresAt           DateTime?
  note                String?          @db.Text
  items               DocumentItem[]
  movements           StockMovement[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([type, status])
  @@index([customerId])
  @@index([referenceDocumentId])
}

model DocumentItem {
  id             String        @id @default(uuid())
  documentId     String
  document       Document      @relation(fields: [documentId], references: [id])
  productId      String
  product        Product       @relation(fields: [productId], references: [id])
  serialNumberId String?
  serialNumber   SerialNumber? @relation(fields: [serialNumberId], references: [id])
  quantity       Int
  unitPrice      Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())

  @@index([documentId])
  @@index([productId])
  @@index([serialNumberId])
}

model StockMovement {
  id             String        @id @default(uuid())
  productId      String
  product        Product       @relation(fields: [productId], references: [id])
  serialNumberId String?
  serialNumber   SerialNumber? @relation(fields: [serialNumberId], references: [id])
  documentId     String?
  document       Document?     @relation(fields: [documentId], references: [id])
  quantity       Int
  movementType   String
  note           String?       @db.Text
  createdAt      DateTime      @default(now())

  @@index([productId])
  @@index([serialNumberId])
  @@index([documentId])
}

model DocumentCounter {
  id        String   @id @default(uuid())
  type      DocumentType
  period    String
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, period])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}

model CompanySetting {
  id        String   @id @default("default")
  name      String
  logoUrl   String?
  taxId     String?
  address   String?  @db.Text
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
